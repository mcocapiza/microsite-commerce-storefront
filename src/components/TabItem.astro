---
// Custom TabItem component that works with the custom Tabs component
// Provides the content for each tab panel
interface Props {
    label: string;
    class?: string;
}

const { label, class: className, ...props } = Astro.props;
---

<div data-label={label} class={className || ""} {...props}>
    <slot />
</div>

<!-- 
This component is intentionally simple - it just provides a container
for tab content with a data-label attribute that the Tabs component
uses to create the tab buttons. The Tabs component handles all the
styling, ARIA attributes, and JavaScript functionality.

The key is the data-label attribute which tells the Tabs component
what text to use for the tab button. The Tabs component will:
1. Find all children with data-label attributes
2. Create tab buttons using the label values
3. Set up proper ARIA attributes and relationships
4. Handle all the tab switching functionality
-->
